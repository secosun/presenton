# Presenton Environment Configuration

# LLM Configuration (choose one)
LLM=
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GOOGLE_API_KEY=
GOOGLE_MODEL=
OLLAMA_URL=
OLLAMA_MODEL=
CUSTOM_LLM_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_MODEL=
CODEX_MODEL=

# Feature Flags
EXTENDED_REASONING=
TOOL_CALLS=
DISABLE_THINKING=
WEB_GROUNDING=
DISABLE_ANONYMOUS_TRACKING=

# Database
DATABASE_URL=

# Pexels API (for images)
PEXELS_API_KEY=

# ComfyUI (for AI images)
COMFYUI_URL=
COMFYUI_WORKFLOW=

# MCP Server Configuration
# Port mapping for MCP Server (port 8001)
# Required for AI Agent integration via MCP protocol
# MCP OpenAPI: app（默认）= 全量接口与 /docs 一致；file= 仅物化子集 openai_spec.json
# PRESENTON_MCP_OPENAPI_SOURCE=app
#
# Next.js（物化/导出链与 /api/v1/nextjs 代理；默认无端口=走本机 80 前端的 /api/*）
# PRESENTON_NEXTJS_BASE_URL=http://127.0.0.1
# PRESENTON_NEXTJS_HTTP_TIMEOUT=300

# Network Configuration (for environments behind proxy)
# NO_PROXY should include localhost, your machine IP, and local network ranges
# Example: NO_PROXY=localhost,127.0.0.1,192.168.3.58,192.168.0.0/16,10.0.0.0/8

# Export download URLs: internal origin uses PRESENTON_HOST / PRESENTON_PORT (see servers/fastapi/utils/export_utils.py).
# Optional public HTTPS origin (no trailing slash). When set, materialize/export JSON includes download_url_public
# (same path as download_url) for external users. Alias: PRESENTON_PUBLIC_BASE_URL.
# PRESENTON_PUBLIC_EXPORT_BASE=https://ppt.example.com

# OpenClaw Gateway（微信扫码绑定；服务端 API 直连内网，与公网穿透无关）
# 网关无域名时：填 Presenton 容器能访问的内网地址，须与网关 docker 暴露端口一致
OPENCLAW_GATEWAY_BASE=http://192.168.3.58:18789
# 须与网关一致：开发与生产默认均为 openclaw-distributed-secret-key（可被 .env 覆盖为强随机串）
OPENCLAW_GATEWAY_TOKEN=openclaw-distributed-secret-key
NEXT_PUBLIC_OPENCLAW_GATEWAY_BASE=http://192.168.3.58:18789
NEXT_PUBLIC_OPENCLAW_GATEWAY_TOKEN=openclaw-distributed-secret-key

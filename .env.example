# Presenton Environment Configuration

# LLM Configuration (choose one)
LLM=
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
GOOGLE_API_KEY=
GOOGLE_MODEL=
OLLAMA_URL=
OLLAMA_MODEL=
CUSTOM_LLM_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_MODEL=
CODEX_MODEL=

# Feature Flags
EXTENDED_REASONING=
TOOL_CALLS=
DISABLE_THINKING=
WEB_GROUNDING=
DISABLE_ANONYMOUS_TRACKING=

# Database
DATABASE_URL=

# Pexels API (for images)
PEXELS_API_KEY=

# ComfyUI (for AI images)
COMFYUI_URL=
COMFYUI_WORKFLOW=

# MCP Server Configuration
# Port mapping for MCP Server (port 8001)
# Required for AI Agent integration via MCP protocol

# Network Configuration (for environments behind proxy)
# NO_PROXY should include localhost, your machine IP, and local network ranges
# Example: NO_PROXY=localhost,127.0.0.1,192.168.3.58,192.168.0.0/16,10.0.0.0/8

# OpenClaw Gateway（微信扫码绑定；服务端 API 直连内网，与公网穿透无关）
# 网关无域名时：填 Presenton 容器能访问的内网地址，须与网关 docker 暴露端口一致
OPENCLAW_GATEWAY_BASE=http://192.168.3.58:18789
# 须与网关一致：开发与生产默认均为 openclaw-distributed-secret-key（可被 .env 覆盖为强随机串）
OPENCLAW_GATEWAY_TOKEN=openclaw-distributed-secret-key
NEXT_PUBLIC_OPENCLAW_GATEWAY_BASE=http://192.168.3.58:18789
NEXT_PUBLIC_OPENCLAW_GATEWAY_TOKEN=openclaw-distributed-secret-key

{
  "openapi": "3.1.0",
  "info": {
    "title": "Presenton API (materialize-only)",
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/ppt/presentation/materialize/async": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Start materialize in the background (returns job_id; poll GET .../materialize/jobs/{job_id}).",
        "operationId": "start_materialize_presentation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MaterializePresentationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Job accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaterializeJobAccepted"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/ppt/presentation/materialize/jobs/{job_id}": {
      "get": {
        "tags": ["Presentation"],
        "summary": "Poll materialize job status and result.",
        "operationId": "get_materialize_job",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Current job state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MaterializeJobStatusResponse"
                }
              }
            }
          },
          "404": {
            "description": "Unknown job_id"
          }
        }
      }
    },
    "/api/v1/ppt/presentation/materialize": {
      "post": {
        "tags": ["Presentation"],
        "summary": "Materialize a presentation from structured slides (no server-side LLM).",
        "operationId": "materialize_presentation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MaterializePresentationRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationPathAndEditPath"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "409": {
            "description": "presentation_id already exists"
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          },
          "502": {
            "description": "Template service (Next.js) unavailable"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MaterializeSlideItem": {
        "type": "object",
        "required": ["layout_id", "content"],
        "properties": {
          "layout_id": { "type": "string" },
          "content": { "type": "object", "additionalProperties": true },
          "outline_summary": { "type": "string" },
          "speaker_note": { "type": "string" },
          "html_content": { "type": "string" },
          "properties": { "type": "object", "additionalProperties": true }
        },
        "title": "MaterializeSlideItem"
      },
      "MaterializePresentationRequest": {
        "type": "object",
        "required": ["template", "slides", "export_as"],
        "properties": {
          "schema_version": { "type": "string" },
          "template": { "type": "string" },
          "slides": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/components/schemas/MaterializeSlideItem" }
          },
          "export_as": { "type": "string", "enum": ["pptx", "pdf"] },
          "language": { "type": "string", "default": "English" },
          "title": { "type": "string" },
          "presentation_id": { "type": "string", "format": "uuid" },
          "content": { "type": "string", "default": "" },
          "instructions": { "type": "string" },
          "tone": { "type": "string" },
          "verbosity": { "type": "string" },
          "theme": { "type": "object", "additionalProperties": true }
        },
        "title": "MaterializePresentationRequest"
      },
      "MaterializeJobAccepted": {
        "type": "object",
        "required": ["job_id", "status"],
        "properties": {
          "job_id": { "type": "string", "format": "uuid" },
          "status": { "type": "string", "enum": ["pending"] }
        },
        "title": "MaterializeJobAccepted"
      },
      "MaterializeJobStatusResponse": {
        "type": "object",
        "required": ["job_id", "status"],
        "properties": {
          "job_id": { "type": "string", "format": "uuid" },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "completed", "failed"]
          },
          "created_at": {
            "anyOf": [{ "type": "string" }, { "type": "null" }]
          },
          "started_at": {
            "anyOf": [{ "type": "string" }, { "type": "null" }]
          },
          "completed_at": {
            "anyOf": [{ "type": "string" }, { "type": "null" }]
          },
          "result": {
            "anyOf": [
              { "$ref": "#/components/schemas/PresentationPathAndEditPath" },
              { "type": "null" }
            ]
          },
          "error": {
            "anyOf": [
              { "type": "object", "additionalProperties": true },
              { "type": "null" }
            ]
          }
        },
        "title": "MaterializeJobStatusResponse"
      },
      "PresentationPathAndEditPath": {
        "properties": {
          "presentation_id": {
            "type": "string",
            "title": "Presentation Id"
          },
          "path": {
            "type": "string",
            "title": "Path",
            "description": "Container file path (e.g., /app_data/exports/xxx.pptx)"
          },
          "download_url": {
            "type": "string",
            "title": "Download URL",
            "description": "Remote download URL via Nginx proxy (e.g., http://host:5000/exports/xxx.pptx)"
          },
          "download_url_public": {
            "type": "string",
            "title": "Public Download URL",
            "description": "Same path as download_url with public HTTPS origin when PRESENTON_PUBLIC_EXPORT_BASE is set (optional)"
          },
          "edit_path": {
            "type": "string",
            "title": "Edit Path"
          }
        },
        "type": "object",
        "required": ["presentation_id", "path", "download_url", "edit_path"],
        "title": "PresentationPathAndEditPath"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": ["loc", "msg", "type"],
        "title": "ValidationError"
      }
    }
  }
}
